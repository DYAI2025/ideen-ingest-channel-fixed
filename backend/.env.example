# Environment Configuration for Ideen Ingest Channel
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME=Ideen Ingest Channel
APP_VERSION=0.1.0
DEBUG=True

# Server Settings
HOST=0.0.0.0
PORT=8000

# File Upload Settings
UPLOAD_DIR=~/ideen-growth-system/seeds
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.md,.txt,.json,.yaml,.yml

# GBrain Settings
GBRAIN_SOURCE=ideas
GBRAIN_PATH=~/.gbrain
GBRAIN_COMMAND=gbrain

# SSH Settings
SSH_ENABLED=True
SSH_PORT=2222
SSH_HOST=localhost

# Graph Settings
GRAPH_CACHE_TTL=300
MAX_NODES=100
MAX_DEPTH=3

# Slack Settings (Required for Slack Integration)
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_LEVEL_TOKEN=xapp-your-app-level-token-here

# Database Settings (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=slack_integration
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slack_integration